# AgentArena — provider API keys.
# Copy this file to ".env" and fill in the keys for the providers you use.
# Bun loads ".env" automatically; ".env" is gitignored so your keys stay private.
# A key set here can also be overridden per-player via provider.apiKey in a match config.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
