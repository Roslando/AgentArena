{
  "name": "agentarena",
  "private": true,
  "workspaces": ["packages/types", "packages/engine", "packages/cli", "packages/game-chess", "packages/web", "packages/server"],
  "scripts": {
    "clean": "rm -rf packages/*/dist",
    "build": "bun run --filter=@agentarena/types build && bun run --filter=@agentarena/engine build && bun run --filter=@agentarena/game-chess build && bun run --filter=@agentarena/cli build",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.9.1",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
